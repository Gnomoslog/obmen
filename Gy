from abc import ABC, abstractmethod

class Employee(ABC):
    def init(self, name, base_salary):
        self.__name = name
        self.__base_salary = base_salary

    @property
    def salary(self):
        return self.__base_salary

    @salary.setter
    def salary(self, value):
        if value < 0:
            raise ValueError("Зарплата не может быть отрицательной")
        self.__base_salary = value

    @property
    def name(self):
        return self.__name

    @abstractmethod
    def calculate_bonus(self):
        pass

    # Расширенное задание
    @property
    def total_compensation(self):
        return self.salary + self.calculate_bonus()


class Manager(Employee):
    def init(self, name, base_salary, team_size):
        super().init(name, base_salary)
        self.team_size = team_size

    def calculate_bonus(self):
        return self.salary * 0.10 * self.team_size


class Developer(Employee):
    def init(self, name, base_salary, programming_language):
        super().init(name, base_salary)
        self.programming_language = programming_language

    def calculate_bonus(self):
        return self.salary * 0.05


# Проверка
if name == "main":
    m = Manager("Анна", 80000, 5)
    d = Developer("Олег", 70000, "Python")

    print(m.name, m.salary, m.calculate_bonus(), m.total_compensation)
    print(d.name, d.salary, d.calculate_bonus(), d.total_compensation)

from abc import ABC, abstractmethod
import math

class Shape(ABC):
    """Базовый абстрактный класс для всех фигур"""
    
    def init(self, name):
        self.__name = name  # приватное поле
    
    @property
    def name(self):        # свойство только для чтения
        return self.__name
    
    @abstractmethod
    def area(self):
        """Вычисление площади"""
        pass
    
    @abstractmethod
    def perimeter(self):
        """Вычисление периметра"""
        pass
    
    def str(self):
        return f"{self.name}: площадь = {self.area():.2f}, периметр = {self.perimeter():.2f}"


class Rectangle(Shape):
    def init(self, name, width, height):
        super().init(name)
        self.__width = width      # приватное поле
        self.__height = height    # приватное поле
    
    @property
    def width(self):
        return self.__width
    
    @property
    def height(self):
        return self.__height
    
    def area(self):
        return self.width * self.height
    
    def perimeter(self):
        return 2 * (self.width + self.height)


class Circle(Shape):
    def init(self, name, radius):
        super().init(name)
        self.__radius = radius    # приватное поле
    
    @property
    def radius(self):
        return self.__radius
    
    def area(self):
        return math.pi * self.__radius ** 2
    
    def perimeter(self):
        return 2 * math.pi * self.__radius


# Полиморфная функция
def describe_shape(shape):
    """Работает с любым объектом, у которого есть name, area, perimeter"""
    print(f"Фигура: {shape.name}")
    print(f"  Площадь: {shape.area():.2f}")
    print(f"  Периметр: {shape.perimeter():.2f}")
    print("-" * 30)


# Демонстрация полиморфизма
if name == "main":
    # Создаём разные фигуры
    rect = Rectangle("Прямоугольник", 5, 3)
    circle = Circle("Круг", 4)
    
    # Полиморфный список
    shapes = [rect, circle]
    
    for s in shapes:
        describe_shape(s)
    
    # Дополнительная проверка через str
    print(rect)
    print(circle)
